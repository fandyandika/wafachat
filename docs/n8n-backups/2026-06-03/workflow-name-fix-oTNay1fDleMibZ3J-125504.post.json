  "nodes": [
    {
      "id": "node-state-wh",
      "name": "State Webhook",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 2,
      "position": [
        240,
        300
      ],
      "parameters": {
        "path": "conversation-state",
        "httpMethod": "POST",
        "responseMode": "responseNode",
        "responseCode": 200
      },
      "webhookId": "conv-state-wh-001"
    },
    {
      "id": "node-state-logic",
      "name": "State Logic",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        460,
        300
      ],
      "parameters": {
        "jsCode": "const body = $input.first().json.body || $input.first().json;\n\ntry {\n  const response = await this.helpers.httpRequest({\n    method: 'POST',\n    url: 'https://helpful-spoonbill-863.convex.site/n8n/state',\n    headers: {\n      'Content-Type': 'application/json',\n      'x-wafachat-adapter-secret': 'f_ILXhpK1otsmumBuAHZcalOQkX8jXSwSQVYqvjaiew',\n    },\n    body,\n    json: true,\n  });\n\n  return [{ json: response }];\n} catch (error) {\n  return [{\n    json: {\n      success: false,\n      error: error.message || 'convex adapter request failed',\n      _action: body.action || null,\n    },\n  }];\n}"
      }
    },
    {
      "id": "node-state-respond",
      "name": "Respond",
      "type": "n8n-nodes-base.respondToWebhook",
      "typeVersion": 1.1,
      "position": [
        680,
        300
      ],
      "parameters": {
        "respondWith": "json",
        "responseBody": "={{ $json }}",
        "options": {
          "responseCode": 200
        }
      }
    },
    {
      "id": "node-list-wh",
      "name": "List State Webhook",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 2,
      "position": [
        240,
        520
      ],
      "parameters": {
        "path": "cs-status",
        "httpMethod": "GET",
        "responseMode": "responseNode",
        "responseCode": 200
      },
      "webhookId": "9cd508fd-6fd8-459a-9c3b-8d63ca0c2ad8"
    },
    {
      "id": "node-list-logic",
      "name": "List State Logic",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        460,
        520
      ],
      "parameters": {
        "jsCode": "const state = $getWorkflowStaticData('global');\n\nconst globalEnabled = state.global_ai_enabled !== false;\n\n// Use phone_index if available, fallback to key enumeration\nconst phones = state.phone_index ||\n  Object.keys(state).filter(k => k !== '__global__' && k !== 'phone_index' && k !== 'daily_stats' && k !== 'global_ai_enabled');\n\nconst customers = phones\n  .map(phone => {\n    const data = state[phone];\n    if (!data || typeof data !== 'object') return null;\n    return {\n      phone,\n      status: data.status || 'active',\n      customerName: data.customerName || '',\n      productName: data.productName || '',\n      csName: data.csName || '',\n      note: data.note || '',\n      updatedAt: data.updatedAt || data.updated_at || null,\n    };\n  })\n  .filter(c => c && c.status !== 'closed');\n\ncustomers.sort((a, b) => {\n  if (a.status === 'handover' && b.status !== 'handover') return -1;\n  if (a.status !== 'handover' && b.status === 'handover') return 1;\n  return a.phone.localeCompare(b.phone);\n});\n\nconst today = new Date().toISOString().split('T')[0];\nconst todayStats = (state.daily_stats || {})[today] || { orders: 0, closings: 0, handovers: 0, closed_today: 0 };\n\nreturn [{ json: {\n  generated_at: new Date().toISOString(),\n  global_ai_enabled: globalEnabled,\n  active_count: customers.filter(c => c.status === 'active').length,\n  handover_count: customers.filter(c => c.status === 'handover').length,\n  total_active: customers.length,\n  stats: todayStats,\n  customers\n} }];"
      }
    },
    {
      "id": "node-list-respond",
      "name": "List Respond",
      "type": "n8n-nodes-base.respondToWebhook",
      "typeVersion": 1.1,
      "position": [
        680,
        520
      ],
      "parameters": {
        "respondWith": "json",
        "responseBody": "={{ $json }}",
        "options": {
          "responseCode": 200
        }
      }
    },
